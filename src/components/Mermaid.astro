---
import mermaidRendererUrl from "../scripts/renderMermaid.ts?url";

interface Props {
  chartFile?: string
}

const { chartFile } = Astro.props

const chartFiles = import.meta.glob("/src/**/*", {
  eager: true,
  import: "default",
  query: "?raw",
}) as Record<string, string>;

const decodeHtmlEntities = (value: string) =>
  value
    .replaceAll("&lt;", "<")
    .replaceAll("&gt;", ">")
    .replaceAll("&amp;", "&")
    .replaceAll("&quot;", '"')
    .replaceAll("&#39;", "'");

const inlineChart = Astro.slots.has("default")
  ? decodeHtmlEntities(
      (await Astro.slots.render("default"))
        .replace(/^<p>/, "")
        .replace(/<\/p>\s*$/, "")
        .replace(/<br\s*\/?>/g, "\n")
        .trim(),
    )
  : "";

const normalizedChartFile = (() => {
  if (!chartFile) {
    return null;
  }

  const trimmedChartFile = chartFile.trim();

  if (trimmedChartFile.startsWith("/")) {
    return trimmedChartFile;
  }

  if (trimmedChartFile.startsWith("src/")) {
    return `/${trimmedChartFile}`;
  }

  return `/src/${trimmedChartFile.replace(/^\.?\//, "")}`;
})();

const chart = normalizedChartFile ? chartFiles[normalizedChartFile] : inlineChart;

if (normalizedChartFile && !chart) {
  throw new Error(
    `Mermaid chart file not found: "${chartFile}". Expected a readable file under src/.`,
  );
}

if (!chart) {
  throw new Error("Mermaid chart is empty. Provide chartFile or inline diagram content.");
}
---

<div class="mermaid-diagram" data-mermaid-diagram>
  <pre data-mermaid-source hidden>{chart}</pre>
  <div class="mermaid-diagram__output" data-mermaid-output aria-label="Mermaid diagram"></div>
  <p class="mermaid-diagram__error" data-mermaid-error hidden></p>
</div>

<script type="module" src={mermaidRendererUrl}></script>

<style>
  .mermaid-diagram {
    margin-block: 1.5rem;
    overflow-x: auto;
  }

  .mermaid-diagram__output {
    display: flex;
    justify-content: center;
    min-width: max-content;
  }

  .mermaid-diagram :global(svg) {
    height: auto;
    max-width: 100%;
  }

  .mermaid-diagram__error {
    color: var(--sl-color-red);
    font-size: var(--sl-text-sm);
    margin: 0;
  }
</style>
