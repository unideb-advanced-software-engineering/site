---
import mermaidRendererUrl from "../scripts/renderMermaid.ts?url";

interface Props {
  chartFile: string
}

const { chartFile } = Astro.props

const chartFiles = import.meta.glob("/src/**/*", {
  eager: true,
  import: "default",
  query: "?raw",
}) as Record<string, string>;

const normalizedChartFile = (() => {
  const trimmedChartFile = chartFile.trim();

  if (trimmedChartFile.startsWith("/")) {
    return trimmedChartFile;
  }

  if (trimmedChartFile.startsWith("src/")) {
    return `/${trimmedChartFile}`;
  }

  return `/src/${trimmedChartFile.replace(/^\.?\//, "")}`;
})();

const chart = chartFiles[normalizedChartFile]

if (normalizedChartFile && !chart) {
  throw new Error(
    `Mermaid chart file not found: "${chartFile}". Expected a readable file under src/.`,
  );
}

if (!chart) {
  throw new Error("Mermaid chart is empty. Provide chartFile or inline diagram content.");
}
---

<div class="mermaid">{chart}</div>

<script type="module" src={mermaidRendererUrl}></script>

<style>
  .mermaid {
    margin-block: 1.5rem;
    overflow-x: auto;
  }

  .mermaid :global(svg) {
    height: auto;
    max-width: 100%;
  }
</style>
